{
  "schema_version": 1,
  "strategy_id": "unified_arb_live",
  "strategy_kind": "unified_arbitrage",
  "run_id": "local",
  "tenant_id": "local",
  "config_path": "config/unified_arbitrage_usdt.yml",
  "command": "cargo",
  "args": [
    "run",
    "-p",
    "rustcta-strategy-unified-arbitrage",
    "--bin",
    "unified-arbitrage-runtime",
    "--",
    "--config",
    "config/unified_arbitrage_usdt.yml",
    "--strategy-id",
    "unified_arb_live",
    "--run-id",
    "local",
    "--tenant-id",
    "local",
    "--account-id",
    "unified_arbitrage",
    "--lock-file",
    "logs/unified_arbitrage/unified_arb_live.lock",
    "--dashboard-snapshot-path",
    "logs/unified_arbitrage/dashboard.json",
    "--command-queue",
    "data/control_api/unified_arb_control_commands.jsonl",
    "--snapshot-interval-ms",
    "5000",
    "--quiet-stdout"
  ],
  "working_dir": ".",
  "log_path": "logs/supervisor/unified_arb_live.log",
  "restart_backoff_ms": 5000,
  "recovery_policy": {
    "restart_on_exit": false,
    "restart_on_stale_heartbeat": false,
    "max_restart_attempts": 0,
    "heartbeat_timeout_ms": null,
    "snapshot_timeout_ms": null,
    "restart_backoff_ms": 5000
  }
}
