{
  "schema_version": 1,
  "strategy_id": "account_position_reporter",
  "strategy_kind": "account_position_report",
  "run_id": "local",
  "tenant_id": "local",
  "config_path": "config/account_position_reporter.yml",
  "command": "cargo",
  "args": [
    "run",
    "-p",
    "rustcta-tools-ops",
    "--",
    "reporter",
    "account-position",
    "render",
    "--config",
    "config/account_position_reporter.yml",
    "--input",
    "config/supervisor/account_position_reporter.input.example.json"
  ],
  "working_dir": ".",
  "log_path": "logs/supervisor/account_position_reporter.log",
  "restart_backoff_ms": 5000,
  "recovery_policy": {
    "restart_on_exit": false,
    "restart_on_stale_heartbeat": false,
    "max_restart_attempts": 0,
    "heartbeat_timeout_ms": null,
    "snapshot_timeout_ms": null,
    "restart_backoff_ms": 5000
  }
}
