{
  "exchange": "bitflyer",
  "operation": "get_fees",
  "product": "spot",
  "transport": "rest",
  "method": "GET",
  "path": "/v1/me/gettradingcommission",
  "auth": "hmac",
  "query": {
    "product_code": {
      "match": "exact",
      "value": "BTC_JPY"
    }
  },
  "headers": {
    "ACCESS-KEY": {
      "match": "non_empty"
    },
    "ACCESS-TIMESTAMP": {
      "match": "non_empty"
    },
    "ACCESS-SIGN": {
      "match": "non_empty"
    }
  },
  "strict_query": true,
  "strict_headers": false,
  "forbid_header_values_containing": [
    "secret"
  ],
  "runtime_boundary": {
    "status": "offline",
    "reason": "Commission endpoint exists, but shared maker/taker normalization and product-code scope policy are not implemented.",
    "adapter_error": "bitflyer.get_fees.no_stable_standard_mapping"
  },
  "body": null
}
