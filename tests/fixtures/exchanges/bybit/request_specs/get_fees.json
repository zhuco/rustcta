{
  "exchange": "bybit",
  "operation": "get_fees",
  "product": "spot/linear/inverse/option",
  "transport": "rest",
  "method": "GET",
  "path": "/v5/account/fee-rate",
  "auth": "signed",
  "query": {
    "category": { "match": "one_of", "values": ["spot", "linear", "inverse", "option"] },
    "symbol": { "match": "optional_uppercase_symbol" },
    "baseCoin": { "match": "optional_uppercase_asset" }
  },
  "headers": {
    "X-BAPI-API-KEY": { "match": "exact", "value": "test-key" },
    "X-BAPI-SIGN": { "match": "non_empty" },
    "X-BAPI-SIGN-TYPE": { "match": "exact", "value": "2" },
    "X-BAPI-TIMESTAMP": { "match": "non_empty" },
    "X-BAPI-RECV-WINDOW": { "match": "exact", "value": "5000" }
  },
  "strict_headers": false,
  "forbid_header_values_containing": ["test-secret"]
}
