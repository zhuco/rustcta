{
  "exchange": "bybit",
  "operation": "place_order",
  "product": "perpetual",
  "transport": "rest",
  "method": "POST",
  "path": "/v5/order/create",
  "auth": "signed",
  "headers": {
    "X-BAPI-API-KEY": { "match": "exact", "value": "test-key" },
    "X-BAPI-SIGN": { "match": "non_empty" },
    "X-BAPI-SIGN-TYPE": { "match": "exact", "value": "2" },
    "X-BAPI-TIMESTAMP": { "match": "non_empty" },
    "X-BAPI-RECV-WINDOW": { "match": "exact", "value": "5000" },
    "Content-Type": { "match": "exact", "value": "application/json" }
  },
  "body_contains": {
    "category": "linear",
    "symbol": "BTCUSDT",
    "side": "Buy",
    "orderType": "Limit",
    "qty": "0.01",
    "price": "25000",
    "orderLinkId": "cli-place",
    "positionIdx": 1
  },
  "strict_headers": false,
  "forbid_header_values_containing": ["test-secret"],
  "signing_vector": "bybit/place_order_limit"
}
