{
  "exchange": "tapbit",
  "operation": "cancel_order_perp",
  "product": "perpetual",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v1/usdt/cancel_order",
  "auth": "signed",
  "headers": {
    "access-key": {"match": "exact", "value": "key"},
    "access-sign": {"match": "non_empty"},
    "access-timestamp": {"match": "non_empty"}
  },
  "body_contains": {"order_id": "P3001"},
  "forbid_header_values_containing": ["secret"]
}
