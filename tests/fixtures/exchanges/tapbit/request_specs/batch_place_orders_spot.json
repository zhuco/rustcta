{
  "exchange": "tapbit",
  "operation": "batch_place_orders",
  "product": "spot",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v1/spot/batch_order",
  "auth": "signed",
  "headers": {
    "access-key": {"match": "exact", "value": "key"},
    "access-sign": {"match": "non_empty"},
    "access-timestamp": {"match": "non_empty"}
  },
  "body_contains": [{"instrument_id": "BTC/USDT"}, {"instrument_id": "BTC/USDT"}],
  "forbid_header_values_containing": ["secret"]
}
