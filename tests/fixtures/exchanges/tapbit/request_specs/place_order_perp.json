{
  "exchange": "tapbit",
  "operation": "place_order_perp",
  "product": "perpetual",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v1/usdt/order",
  "auth": "signed",
  "headers": {
    "access-key": {"match": "exact", "value": "key"},
    "access-sign": {"match": "non_empty"},
    "access-timestamp": {"match": "non_empty"}
  },
  "body_contains": {"instrument_id": "BTC-SWAP", "position_side": "long", "direction": "1"},
  "forbid_header_values_containing": ["secret"]
}
