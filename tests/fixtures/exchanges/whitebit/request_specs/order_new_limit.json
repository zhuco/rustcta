{
  "exchange": "whitebit",
  "operation": "place_order",
  "product": "spot",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v4/order/new",
  "auth": "signed",
  "headers": {
    "x-txc-apikey": { "match": "exact", "value": "key" },
    "x-txc-payload": { "match": "non_empty" },
    "x-txc-signature": { "match": "non_empty" },
    "content-type": { "match": "exact", "value": "application/json" }
  },
  "body_contains": {
    "request": "/api/v4/order/new",
    "market": "BTC_USDT",
    "side": "buy",
    "amount": "0.02",
    "price": "65000",
    "clientOrderId": "CLIENTLIMIT1"
  },
  "forbid_header_values_containing": ["secret"],
  "signing_vector": "whitebit/order_new_limit"
}
