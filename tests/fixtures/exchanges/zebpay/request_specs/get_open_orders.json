{
  "operation": "zebpay.get_open_orders",
  "request_spec_only": false,
  "runtime": "guarded_private_rest",
  "trade_enabled": false,
  "method": "GET",
  "path": "/orders",
  "query": {
    "trade_pair": "BTC-INR",
    "status": "pending",
    "orderid": 0,
    "page": 1,
    "limit": 500
  },
  "headers": {
    "client_id": "<redacted:client-id>",
    "timestamp": "<redacted:unix-ms>",
    "RequestId": "<redacted:uuid>",
    "Authorization": "<redacted:bearer-token>"
  },
  "credential_scope": "read_only",
  "runtime_guard": "ZEBPAY_PRIVATE_REST_ENABLED or RUSTCTA_ZEBPAY_PRIVATE_REST_ENABLED plus client_id/client_secret/access_token"
}
