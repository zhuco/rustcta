{
  "exchange": "phemex",
  "operation": "perp_place_order",
  "product": "perpetual",
  "transport": "rest",
  "method": "PUT",
  "path": "/g-orders/create",
  "auth": "signed",
  "query": {
    "symbol": {
      "match": "exact",
      "value": "BTCUSDT"
    },
    "side": {
      "match": "exact",
      "value": "Buy"
    },
    "orderQtyRq": {
      "match": "exact",
      "value": "0.001"
    },
    "clOrdID": {
      "match": "exact",
      "value": "client-1"
    }
  },
  "headers": {
    "x-phemex-access-token": {
      "match": "exact",
      "value": "key"
    },
    "x-phemex-request-expiry": {
      "match": "non_empty"
    },
    "x-phemex-request-signature": {
      "match": "non_empty"
    }
  },
  "strict_query": false,
  "strict_headers": false,
  "body": null,
  "signing_vector": "phemex/rest_query_order"
}
