{
  "exchange": "phemex",
  "operation": "recent_fills",
  "product": "perpetual",
  "transport": "rest",
  "method": "GET",
  "path": "/api-data/g-futures/trades",
  "auth": "signed",
  "query": {
    "symbol": {
      "match": "exact",
      "value": "BTCUSDT"
    },
    "limit": {
      "match": "exact",
      "value": "200"
    }
  },
  "headers": {
    "x-phemex-access-token": {
      "match": "exact",
      "value": "key"
    },
    "x-phemex-request-expiry": {
      "match": "non_empty"
    },
    "x-phemex-request-signature": {
      "match": "non_empty"
    }
  },
  "strict_query": false,
  "strict_headers": false,
  "body": null
}
