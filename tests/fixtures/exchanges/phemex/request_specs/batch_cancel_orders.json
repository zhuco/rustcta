{
  "exchange": "phemex",
  "operation": "batch_cancel_orders",
  "product": "perpetual",
  "transport": "rest",
  "method": "DELETE",
  "path": "/g-orders",
  "auth": "signed",
  "query": {
    "symbol": {
      "match": "exact",
      "value": "BTCUSDT"
    },
    "clOrdID": {
      "match": "non_empty"
    },
    "posSide": {
      "match": "exact",
      "value": "Merged"
    }
  },
  "headers": {
    "x-phemex-access-token": {
      "match": "exact",
      "value": "key"
    },
    "x-phemex-request-expiry": {
      "match": "non_empty"
    },
    "x-phemex-request-signature": {
      "match": "non_empty"
    }
  },
  "strict_query": false,
  "strict_headers": false,
  "body": null
}
