{
  "exchange": "phemex",
  "operation": "perp_fees",
  "product": "perpetual",
  "transport": "rest",
  "method": "GET",
  "path": "/api-data/futures/fee-rate",
  "auth": "signed",
  "query": {
    "settleCurrency": {
      "match": "exact",
      "value": "USDT"
    }
  },
  "headers": {
    "x-phemex-access-token": {
      "match": "exact",
      "value": "key"
    },
    "x-phemex-request-expiry": {
      "match": "non_empty"
    },
    "x-phemex-request-signature": {
      "match": "non_empty"
    }
  },
  "strict_query": false,
  "strict_headers": false,
  "body": null
}
