{
  "exchange": "hollaex",
  "operation": "get_recent_fills",
  "product": "spot",
  "transport": "rest",
  "method": "GET",
  "path": "/v2/user/trades",
  "auth": "signed",
  "query": {
    "symbol": {
      "match": "exact",
      "value": "xht-usdt"
    }
  },
  "headers": {
    "api-key": {
      "match": "exact",
      "value": "test-key"
    },
    "api-signature": {
      "match": "present"
    },
    "api-expires": {
      "match": "present"
    }
  },
  "strict_query": false,
  "strict_headers": false,
  "strict_body": true,
  "runtime_guard": "HOLLAEX_PRIVATE_REST_ENABLED plus API key/secret required"
}
