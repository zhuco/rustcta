{
  "exchange": "binance",
  "operation": "place_order",
  "product": "perpetual",
  "transport": "rest",
  "method": "POST",
  "path": "/fapi/v1/order",
  "auth": "signed",
  "query": {
    "symbol": {
      "match": "exact",
      "value": "BTCUSDT"
    },
    "side": {
      "match": "exact",
      "value": "SELL"
    },
    "type": {
      "match": "exact",
      "value": "LIMIT"
    },
    "timeInForce": {
      "match": "exact",
      "value": "IOC"
    },
    "quantity": {
      "match": "exact",
      "value": "0.01000000"
    },
    "price": {
      "match": "exact",
      "value": "65000.00000000"
    },
    "newClientOrderId": {
      "match": "exact",
      "value": "perp-place"
    },
    "reduceOnly": {
      "match": "exact",
      "value": "true"
    },
    "positionSide": {
      "match": "exact",
      "value": "SHORT"
    },
    "timestamp": {
      "match": "non_empty"
    },
    "recvWindow": {
      "match": "exact",
      "value": "5000"
    },
    "signature": {
      "match": "non_empty"
    }
  },
  "headers": {
    "X-MBX-APIKEY": {
      "match": "exact",
      "value": "test-key"
    },
    "Content-Type": {
      "match": "exact",
      "value": "application/x-www-form-urlencoded"
    }
  },
  "body": null,
  "strict_query": true,
  "strict_headers": false,
  "forbid_query_values_containing": [
    "test-secret"
  ]
}
