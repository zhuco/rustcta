{
  "exchange": "binance",
  "operation": "place_quote_market_order",
  "product": "spot",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v3/order",
  "auth": "signed",
  "query": {
    "symbol": {
      "match": "exact",
      "value": "BTCUSDT"
    },
    "side": {
      "match": "exact",
      "value": "BUY"
    },
    "type": {
      "match": "exact",
      "value": "MARKET"
    },
    "quoteOrderQty": {
      "match": "exact",
      "value": "25.50"
    },
    "newClientOrderId": {
      "match": "exact",
      "value": "cli-quote"
    },
    "timestamp": {
      "match": "non_empty"
    },
    "recvWindow": {
      "match": "exact",
      "value": "5000"
    },
    "signature": {
      "match": "non_empty"
    }
  },
  "headers": {
    "X-MBX-APIKEY": {
      "match": "exact",
      "value": "test-key"
    },
    "Content-Type": {
      "match": "exact",
      "value": "application/x-www-form-urlencoded"
    }
  },
  "body": null,
  "strict_query": true,
  "strict_headers": false,
  "forbid_query_values_containing": [
    "test-secret"
  ],
  "signing_vector": "binance/place_order_limit"
}
