{
  "exchange": "bit2c",
  "operation": "get_balances",
  "product": "spot",
  "transport": "rest",
  "method": "GET",
  "path": "/Account/Balance",
  "auth": "signed",
  "query": {
    "nonce": {
      "match": "non_empty"
    }
  },
  "headers": {
    "key": {
      "match": "non_empty"
    },
    "sign": {
      "match": "non_empty"
    },
    "content-type": {
      "match": "exact",
      "value": "application/x-www-form-urlencoded"
    }
  },
  "strict_headers": false,
  "forbid_query_values_containing": [
    "fixture_secret"
  ],
  "forbid_header_values_containing": [
    "fixture_secret"
  ],
  "signing_vector": "tests/fixtures/exchanges/bit2c/signing_vectors/private_hmac_sha512_form.json"
}
