{
  "exchange": "alpaca",
  "operation": "get_symbol_rules",
  "product": "spot",
  "transport": "rest",
  "method": "GET",
  "path": "/v1/assets",
  "auth": "api_key",
  "query": {
    "asset_class": {
      "match": "exact",
      "value": "crypto"
    },
    "status": {
      "match": "exact",
      "value": "active"
    }
  },
  "headers": {
    "APCA-API-KEY-ID": {
      "match": "exact",
      "value": "test-key"
    },
    "APCA-API-SECRET-KEY": {
      "match": "exact",
      "value": "test-secret"
    }
  },
  "forbid_query_values_containing": [
    "test-secret"
  ]
}
