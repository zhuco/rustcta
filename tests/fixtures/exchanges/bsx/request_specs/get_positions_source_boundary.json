        "unrealizedPnl": "1.00",
        "marginMode": "cross"
      }
    ],
    "equity": "1200.00"
  },
  "runtime_boundary": "BSX get_positions is source-boundary only until a stable account positions path, account headers, permission scope, position parser, and private REST/WS reconciliation are audited.",
  "runtime_enabled": false,
  "trade_enabled": false,
  "secret_free": true
}
