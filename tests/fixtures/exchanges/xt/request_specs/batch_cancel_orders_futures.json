{
  "exchange": "xt",
  "operation": "batch_cancel_orders_futures",
  "product": "perpetual",
  "transport": "rest",
  "method": "POST",
  "path": "/future/trade/v1/order/cancel-batch",
  "auth": "signed",
  "headers": {
    "validate-appkey": {"match": "exact", "value": "key"},
    "validate-timestamp": {"match": "non_empty"},
    "validate-signature": {"match": "non_empty"}
  },
  "forbid_header_values_containing": ["secret"]
}
