{
  "exchange": "weex",
  "operation": "weex_place_order_perpetual",
  "product": "perpetual",
  "transport": "rest",
  "method": "POST",
  "path": "/capi/v3/order",
  "auth": "signed",
  "headers": {
    "access-key": {"match": "exact", "value": "key"},
    "access-sign": {"match": "non_empty"},
    "access-passphrase": {"match": "exact", "value": "passphrase"},
    "access-timestamp": {"match": "non_empty"}
  },
  "body_contains": {
    "symbol": "BTCUSDT",
    "side": "BUY",
    "type": "LIMIT",
    "timeInForce": "GTC",
    "positionSide": "LONG"
  },
  "forbid_query_values_containing": ["secret"],
  "forbid_header_values_containing": ["secret"],
  "signing_vector": "access-place-perpetual-limit"
}
