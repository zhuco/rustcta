{
  "exchange": "hibachi",
  "operation": "get_recent_fills",
  "product": "perpetual",
  "transport": "rest",
  "method": "GET",
  "path": "/trade/account/trades",
  "auth": "api_key",
  "query": {
    "accountId": { "match": "exact", "value": "42" },
    "symbol": { "match": "exact", "value": "BTC/USDT-P" },
    "page": { "match": "exact", "value": "1" },
    "limit": { "match": "exact", "value": "100" }
  },
  "headers": {
    "Authorization": { "match": "non_empty" }
  },
  "strict_query": false,
  "forbid_header_values_containing": ["real", "secret"]
}
