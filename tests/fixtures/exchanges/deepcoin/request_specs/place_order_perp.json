{
  "exchange": "deepcoin",
  "operation": "place_order_perp",
  "product": "perpetual",
  "transport": "rest",
  "method": "POST",
  "path": "/deepcoin/trade/order",
  "auth": "signed",
  "headers": {
    "dc-access-key": {"match": "exact", "value": "key"},
    "dc-access-sign": {"match": "non_empty"},
    "dc-access-timestamp": {"match": "non_empty"},
    "dc-access-passphrase": {"match": "exact", "value": "pass"}
  },
  "body_contains": {"instId": "BTC-USDT-SWAP", "posSide": "long", "mrgPosition": "merge", "clOrdId": "LIMIT1"},
  "forbid_header_values_containing": ["secret"]
}
