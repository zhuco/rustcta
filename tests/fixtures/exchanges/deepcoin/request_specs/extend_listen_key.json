{
  "exchange": "deepcoin",
  "operation": "extend_listen_key",
  "product": "private_stream",
  "transport": "rest",
  "method": "GET",
  "path": "/deepcoin/listenkey/extend",
  "auth": "signed",
  "headers": {
    "dc-access-key": {"match": "exact", "value": "key"},
    "dc-access-sign": {"match": "non_empty"},
    "dc-access-timestamp": {"match": "non_empty"},
    "dc-access-passphrase": {"match": "exact", "value": "pass"}
  },
  "forbid_header_values_containing": ["secret"]
}
