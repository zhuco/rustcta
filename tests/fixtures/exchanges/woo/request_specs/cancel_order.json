{
  "exchange": "woo",
  "operation": "cancel_order",
  "product": "spot",
  "transport": "rest",
  "method": "DELETE",
  "path": "/v3/trade/order",
  "auth": "signed",
  "headers": {
    "x-api-key": { "match": "exact", "value": "key" },
    "x-api-signature": { "match": "non_empty" },
    "x-api-timestamp": { "match": "non_empty" }
  },
  "query": {
    "symbol": { "match": "exact", "value": "SPOT_BTC_USDT" },
    "orderId": { "match": "exact", "value": "2001" }
  },
  "forbid_header_values_containing": ["secret"]
}
