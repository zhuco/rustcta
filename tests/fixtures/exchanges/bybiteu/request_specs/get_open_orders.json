{
  "exchange": "bybiteu",
  "profile_of": "bybit",
  "operation": "get_open_orders",
  "product": "perpetual",
  "transport": "rest",
  "method": "GET",
  "path": "/v5/order/realtime",
  "auth": "signed_shape_only_private_disabled",
  "query": {
    "category": { "match": "exact", "value": "linear" },
    "symbol": { "match": "exact", "value": "BTCUSDT" }
  },
  "headers": {
    "X-BAPI-API-KEY": { "match": "non_empty" },
    "X-BAPI-SIGN": { "match": "non_empty" },
    "X-BAPI-SIGN-TYPE": { "match": "exact", "value": "2" },
    "X-BAPI-TIMESTAMP": { "match": "non_empty" },
    "X-BAPI-RECV-WINDOW": { "match": "exact", "value": "5000" }
  },
  "strict_headers": false,
  "forbid_header_values_containing": ["test-secret"],
  "runtime_boundary": "EU profile private open-order readback is disabled pending broker third-party application scope audit."
}
