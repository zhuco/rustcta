{
  "exchange": "okx",
  "operation": "amend_order",
  "product": "spot",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v5/trade/amend-order",
  "auth": "signed",
  "query": {},
  "headers": {
    "OK-ACCESS-KEY": {
      "match": "exact",
      "value": "key"
    },
    "OK-ACCESS-SIGN": {
      "match": "non_empty"
    },
    "OK-ACCESS-TIMESTAMP": {
