{
  "exchange": "okx",
  "operation": "cancel_all_orders",
  "product": "spot",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v5/trade/cancel-batch-orders",
  "auth": "signed",
  "query": {},
  "headers": {
    "OK-ACCESS-KEY": {
      "match": "exact",
      "value": "key"
    },
    "OK-ACCESS-SIGN": {
      "match": "non_empty"
    },
    "OK-ACCESS-TIMESTAMP": {
      "match": "non_empty"
    },
    "OK-ACCESS-PASSPHRASE": {
      "match": "exact",
      "value": "passphrase"
    },
    "Content-Type": {
      "match": "exact",
      "value": "application/json"
    }
  },
  "strict_query": true,
  "strict_headers": false,
  "forbid_header_values_containing": [
    "secret"
  ],
  "signing_vector": "okx/place_order",
  "body": [
    {
      "instId": "BTC-USDT",
      "ordId": "2003"
    }
  ]
}
