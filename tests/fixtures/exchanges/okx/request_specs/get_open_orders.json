{
  "exchange": "okx",
  "operation": "get_open_orders",
  "product": "spot",
  "transport": "rest",
  "method": "GET",
  "path": "/api/v5/trade/orders-pending",
  "auth": "signed",
  "query": {
    "instType": {
      "match": "exact",
      "value": "SPOT"
    },
    "instId": {
      "match": "exact",
      "value": "BTC-USDT"
    }
  },
  "headers": {
    "OK-ACCESS-KEY": {
      "match": "exact",
      "value": "key"
    },
    "OK-ACCESS-SIGN": {
      "match": "non_empty"
    },
    "OK-ACCESS-TIMESTAMP": {
      "match": "non_empty"
    },
    "OK-ACCESS-PASSPHRASE": {
      "match": "exact",
      "value": "passphrase"
    },
    "Content-Type": {
      "match": "exact",
      "value": "application/json"
    }
  },
  "strict_query": true,
  "strict_headers": false,
  "forbid_header_values_containing": [
    "secret"
  ],
  "signing_vector": "okx/query_order",
  "body": null
}
