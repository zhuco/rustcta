{
  "exchange": "bitget",
  "operation": "get_open_orders",
  "product": "spot",
  "transport": "rest",
  "method": "GET",
  "path": "/api/v2/spot/trade/unfilled-orders",
  "auth": "signed",
  "query": {
    "symbol": { "match": "exact", "value": "BTCUSDT" }
  },
  "headers": {
    "ACCESS-KEY": { "match": "exact", "value": "key" },
    "ACCESS-SIGN": { "match": "non_empty" },
    "ACCESS-TIMESTAMP": { "match": "non_empty" },
    "ACCESS-PASSPHRASE": { "match": "exact", "value": "passphrase" }
  },
  "forbid_header_values_containing": ["secret"],
  "signing_vector": "bitget/place_order_limit"
}
