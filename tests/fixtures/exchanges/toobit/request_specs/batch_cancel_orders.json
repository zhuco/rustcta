{
  "exchange": "toobit",
  "operation": "batch_cancel_orders",
  "product": "perpetual",
  "transport": "rest",
  "method": "DELETE",
  "path": "/api/v1/futures/cancelOrderByIds",
  "auth": "signed",
  "headers": {
    "X-BB-APIKEY": { "match": "exact", "value": "key" }
  },
  "query": {
    "ids": { "match": "exact", "value": "2001%2C2002" },
    "recvWindow": { "match": "exact", "value": "5000" },
    "timestamp": { "match": "non_empty" },
    "signature": { "match": "non_empty" }
  },
  "forbid_query_values_containing": ["secret"]
}
