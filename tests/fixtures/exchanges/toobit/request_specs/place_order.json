{
  "exchange": "toobit",
  "operation": "place_order",
  "product": "spot",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v1/spot/order",
  "auth": "signed",
  "headers": {
    "X-BB-APIKEY": { "match": "exact", "value": "key" }
  },
  "query": {
    "symbol": { "match": "exact", "value": "BTCUSDT" },
    "side": { "match": "exact", "value": "BUY" },
    "type": { "match": "exact", "value": "LIMIT" },
    "newClientOrderId": { "match": "exact", "value": "client-1" },
    "recvWindow": { "match": "exact", "value": "5000" },
    "timestamp": { "match": "non_empty" },
    "signature": { "match": "non_empty" }
  },
  "forbid_query_values_containing": ["secret"]
}
