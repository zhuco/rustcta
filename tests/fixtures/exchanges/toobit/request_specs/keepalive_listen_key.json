{
  "exchange": "toobit",
  "operation": "keepalive_listen_key",
  "product": "spot",
  "transport": "rest",
  "method": "PUT",
  "path": "/api/v1/userDataStream",
  "auth": "signed",
  "headers": {
    "X-BB-APIKEY": { "match": "exact", "value": "key" }
  },
  "query": {
    "listenKey": { "match": "exact", "value": "listen-key" },
    "recvWindow": { "match": "exact", "value": "5000" },
    "timestamp": { "match": "non_empty" },
    "signature": { "match": "non_empty" }
  },
  "forbid_query_values_containing": ["secret"]
}
