{
  "operation": "coinone.place_order",
  "method": "POST",
  "path": "/v2.1/order",
  "headers": {
    "X-COINONE-PAYLOAD": "<base64-json>",
    "X-COINONE-SIGNATURE": "<hmac-sha512-hex>"
  },
  "body": {
    "access_token": "<redacted>",
    "nonce": "<uuid>",
    "quote_currency": "KRW",
    "target_currency": "BTC",
    "type": "LIMIT",
    "side": "BUY",
    "qty": "0.01",
    "price": "100000000",
    "user_order_id": "C-1"
  }
}
