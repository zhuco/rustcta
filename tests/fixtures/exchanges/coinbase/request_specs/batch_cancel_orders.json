{
  "exchange": "coinbase",
  "operation": "batch_cancel_orders",
  "product": "spot",
  "transport": "rest",
  "method": "POST",
  "path": "/orders/batch_cancel",
  "auth": "signed",
  "headers": {
    "authorization": { "match": "exact", "value": "Bearer test.jwt" }
  },
  "body_contains": {
    "order_ids": ["order-1", "order-2"]
  },
  "forbid_header_values_containing": ["secret"]
}
