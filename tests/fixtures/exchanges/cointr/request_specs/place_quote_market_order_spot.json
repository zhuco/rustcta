{
  "exchange": "cointr",
  "operation": "cointr.place_quote_market_order",
  "product": "spot",
  "transport": "rest",
  "method": "POST",
  "path": "/api/v2/spot/trade/place-order",
  "auth": "signed",
  "headers": {
    "access-key": { "match": "exact", "value": "key" },
    "access-sign": { "match": "non_empty" },
    "access-timestamp": { "match": "non_empty" },
    "access-passphrase": { "match": "non_empty" }
  },
  "body_contains": {
    "symbol": "BTCUSDT",
    "side": "buy",
    "orderType": "market",
    "size": "25",
    "clientOid": "Q1",
    "recvWindow": 5000
  }
}
