{
  "exchange": "aark",
  "underlying_api_profile": "orderly_evm",
  "operation": "get_balances",
  "product": "perpetual",
  "transport": "rest",
  "method": "GET",
  "path": "/v1/client/holding",
  "auth": "signed",
  "headers": {
    "orderly-account-id": { "match": "non_empty" },
    "orderly-key": { "match": "non_empty" },
    "orderly-signature": { "match": "non_empty" },
    "orderly-timestamp": { "match": "exact", "value": "1700000000000" }
  },
  "query": {},
  "strict_query": true,
  "strict_headers": false,
  "strict_body": true,
  "forbid_header_values_containing": ["real", "secret", "private"],
  "signing_vector": "tests/fixtures/exchanges/aark/signing_vectors/orderly_ed25519_boundary.json",
  "account_scope": {
    "required": ["orderly_account_id", "orderly_key"],
    "credential_scopes": ["read_only"],
    "account_requirements": ["aark_orderly_account_onboarding"]
  },
  "response_sample": {
    "success": true,
    "data": {
      "holding": [
        {
          "token": "USDC",
          "holding": "1250.500000",
          "pending_short": "0",
          "pending_long": "0",
          "updated_time": 1700000000000
        }
      ]
    }
  },
  "parser_boundary": {
    "balance_fields": ["token", "holding", "pending_short", "pending_long"],
    "collateral_equity_mapping": "not_wired",
    "precision_source": "Orderly public token metadata or account response audit required"
  },
  "runtime_boundary": "Aark get_balances is request-spec only until Aark/Orderly account onboarding, Ed25519 signer wiring, balance parser, collateral/equity mapping, and read-only reconciliation are audited.",
  "runtime_enabled": false,
  "trade_enabled": false,
  "secret_free": true
}
