{
  "exchange": "binanceus",
  "operation": "get_fees",
  "product": "spot",
  "transport": "rest",
  "method": "GET",
  "path": "/sapi/v1/asset/query/trading-fee",
  "auth": "signed",
  "query": {
    "symbol": {
      "match": "exact",
      "value": "BTCUSDT"
    },
    "timestamp": {
      "match": "non_empty"
    },
    "recvWindow": {
      "match": "exact",
      "value": "5000"
    },
    "signature": {
      "match": "non_empty"
    }
  },
  "headers": {
    "X-MBX-APIKEY": {
      "match": "exact",
      "value": "test-key"
    },
    "Content-Type": {
      "match": "exact",
      "value": "application/x-www-form-urlencoded"
    }
  },
  "body": null,
  "strict_query": true,
  "strict_headers": false,
  "forbid_query_values_containing": [
    "test-secret"
  ],
  "signing_vector": "binanceus/place_order_limit"
}
