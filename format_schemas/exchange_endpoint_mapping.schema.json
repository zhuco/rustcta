{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustcta.local/schemas/exchange_endpoint_mapping.schema.json",
  "title": "RustCTA exchange endpoint mapping",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exchange"
  ],
  "anyOf": [
    {
      "required": [
        "endpoints"
      ]
    },
    {
      "required": [
        "operations"
      ]
    }
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "exchange": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "adapter": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "status_date": {
      "type": [
        "string",
        "object"
      ]
    },
    "market_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/product"
      }
    },
    "products": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/product"
      }
    },
    "rest": {
      "$ref": "#/$defs/rest"
    },
    "rest_base_url": {
      "type": "string",
      "minLength": 1
    },
    "base_urls": {
      "type": "object",
      "additionalProperties": true
    },
    "auth": {
      "type": "object",
      "additionalProperties": true
    },
    "rate_limits": {
      "type": "object",
      "additionalProperties": true
    },
    "rate_limit_plan": {
      "type": "object",
      "additionalProperties": true
    },
    "pagination": {
      "type": "object",
      "additionalProperties": true
    },
    "reconciliation": {
      "type": "object",
      "additionalProperties": true
    },
    "batch": {
      "type": "object",
      "additionalProperties": true
    },
    "websocket": {
      "type": "object",
      "additionalProperties": true
    },
    "websocket_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "streams": {
      "type": [
        "object",
        "array"
      ],
      "additionalProperties": true
    },
    "capabilities_v2": {
      "type": "object",
      "additionalProperties": true
    },
    "operations": {
      "type": "object",
      "additionalProperties": true
    },
    "unsupported": {
      "type": "array",
      "items": {
        "type": [
          "object",
          "string"
        ]
      }
    },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/endpoint"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status": {
          "enum": [
            "draft",
            "validated",
            "live_verified"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "last_reviewed": {
          "type": [
            "string",
            "object"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "rest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "base_url": {
          "type": "string",
          "format": "uri"
        },
        "testnet_base_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "product",
        "transport"
      ],
      "properties": {
        "operation": {
          "type": "string",
          "pattern": "^[a-z0-9_.]+$"
        },
        "product": {
          "$ref": "#/$defs/product"
        },
        "transport": {
          "enum": [
            "rest",
            "websocket",
            "socket_io",
            "socketio",
            "json_rpc"
          ]
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "auth": {
          "$ref": "#/$defs/authMode"
        },
        "credential_scopes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/credentialScope"
          }
        },
        "rate_limit_bucket": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "integer",
          "minimum": 0
        },
        "request_spec_required": {
          "type": "boolean"
        },
        "native_batch": {
          "type": "boolean"
        },
        "atomicity": {
          "$ref": "#/$defs/atomicity"
        },
        "testnet": {
          "type": "boolean"
        },
        "official_doc": {
          "type": "string",
          "minLength": 1
        },
        "support": {
          "$ref": "#/$defs/support"
        },
        "reason": {
          "type": "string"
        },
        "sign_path": {
          "type": "string"
        },
        "market_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/product"
          }
        },
        "request_spec": {
          "$ref": "#/$defs/specRef"
        },
        "request_spec_fixture": {
          "type": "string",
          "minLength": 1
        },
        "response_parser": {
          "$ref": "#/$defs/specRef"
        },
        "max_items": {
          "type": "integer",
          "minimum": 1
        },
        "params": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "body": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "product": {
      "enum": [
        "spot",
        "margin",
        "perpetual",
        "linear_perp",
        "inverse_perp",
        "inverse_future",
        "future",
        "futures",
        "option",
        "options",
        "mixed"
      ]
    },
    "authMode": {
      "enum": [
        "none",
        "api_key",
        "hmac",
        "signed",
        "jwt",
        "bearer",
        "listen_key",
        "md5_hmac_sha256",
        "unsupported"
      ]
    },
    "credentialScope": {
      "enum": [
        "read_only",
        "trade",
        "transfer",
        "withdraw"
      ]
    },
    "atomicity": {
      "enum": [
        "atomic",
        "partial",
        "non_atomic",
        "unknown",
        "not_applicable",
        "unsupported"
      ]
    },
    "support": {
      "enum": [
        "native",
        "composed",
        "rest_fallback",
        "parser_only",
        "spec_only",
        "unsupported",
        "unsupported_unverified"
      ]
    },
    "specRef": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status": {
          "enum": [
            "implemented",
            "fixture_only",
            "planned",
            "not_required",
            "unsupported"
          ]
        }
      }
    }
  }
}
