[Unit]
Description=RustCTA URL Manager
After=network.target

[Service]
Type=simple
User=cta
Group=cta
WorkingDirectory=/home/cta/rustcta
Environment=RUST_LOG=info
ExecStart=/home/cta/rustcta/target/debug/url_manager --host 127.0.0.1 --port 8090 --data /home/cta/rustcta/config/url_manager.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
